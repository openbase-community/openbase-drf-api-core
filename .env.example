DJANGO_DEBUG=1
DJANGO_SECRET_KEY='insecure-secret-key'
ALLOWED_HOSTS='*'
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appdata
REDIS_URL=redis://localhost:6379
# Generate a local dev key with:
# openssl genpkey -algorithm RSA -out headless-jwt-private-key.pem -pkeyopt rsa_keygen_bits:2048
HEADLESS_JWT_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----\nreplace-with-local-dev-private-key\n-----END PRIVATE KEY-----'
RESEND_API_KEY='re_replace_me'
CONTACT_NOTIFICATION_EMAIL='admin@example.com'
